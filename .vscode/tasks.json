{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "windows": {
        "command": "cd src/backend && ..\\..\\venv\\Scripts\\uvicorn.exe main:app --reload"
      },
      "osx": {
        "command": "cd '${workspaceFolder}/src/backend' && '${workspaceFolder}/.venv/bin/uvicorn' main:app --reload"
      },
      "linux": {
        "command": "cd '${workspaceFolder}/src/backend' && '${workspaceFolder}/.venv/bin/uvicorn' main:app --reload"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "app",
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\.vscode\\scripts\\start.ps1"
        ]
      },
      "osx": {
        "command": "bash",
        "args": ["${workspaceFolder}/.vscode/scripts/start.sh"]
      },
      "linux": {
        "command": "bash",
        "args": ["${workspaceFolder}/.vscode/scripts/start.sh"]
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "app",
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Start App",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "dependsOrder": "parallel",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Stop App",
      "type": "shell",
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\.vscode\\scripts\\stop.ps1"
        ]
      },
      "osx": {
        "command": "bash",
        "args": ["${workspaceFolder}/.vscode/scripts/stop.sh"]
      },
      "linux": {
        "command": "bash",
        "args": ["${workspaceFolder}/.vscode/scripts/stop.sh"]
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    }
  ]
}
