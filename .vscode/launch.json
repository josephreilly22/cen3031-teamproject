{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Full Stack",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "preLaunchTask": "Start Frontend",
      "postDebugTask": "Stop App",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/src/backend",
      "console": "integratedTerminal"
    }
  ]
}
